&CONTROL
  calculation = 'scf'
  prefix      = 'Al2O3-Bands'
  outdir      = './tmp'
  pseudo_dir  = './pseudo'
  verbosity   = 'high'
/

&SYSTEM
  ibrav     = 0
  nat       = 10
  ntyp      = 2
  input_dft = 'PBE'

  ecutwfc   = 80
  ecutrho   = 640

  occupations = 'fixed'
/

&ELECTRONS
  electron_maxstep = 150
  conv_thr         = 1.0d-8
  mixing_beta      = 0.2
  diagonalization  = 'david'
/

